{
  "name": "nestjs-go-export-excel-wasm",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\"",
    "format:check": "prettier --check \"{src,test,prisma}/**/*.{ts,js,json,md,yml,yaml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:cov": "vitest run --config vitest.unit.config.ts --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:comparison": "bun test/export-comparison.js",
    "prepare": "sh -c 'git rev-parse --show-toplevel >/dev/null 2>&1 && git config core.hooksPath nestjs-go-export-excel-wasm/.husky || true'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init-sqlite",
    "prisma:seed": "ts-node --project tsconfig.json prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "build:wasm": "cd excel-streamer && cp \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" . && GOOS=js GOARCH=wasm go build -o excel_bridge.wasm excel_bridge.go",
    "build:rust-wasm": "bash -lc 'export PATH=\"$HOME/.cargo/bin:$PATH\"; command -v cargo >/dev/null || { echo \"cargo is required\" >&2; exit 1; }; command -v wasm-bindgen >/dev/null || cargo install wasm-bindgen-cli --version 0.2.114 --locked; rustup target add wasm32-unknown-unknown >/dev/null 2>&1 || true; cd rust-excel-streamer && cargo build --release --target wasm32-unknown-unknown && mkdir -p pkg && wasm-bindgen --target nodejs --out-dir pkg target/wasm32-unknown-unknown/release/rust_excel_streamer.wasm'",
    "test:rust-wasm": "node rust-excel-streamer/test_wasm.js",
    "test:rust-wasm:service": "vitest run --config vitest.unit.config.ts src/export/services/rust-wasm-excel.service.spec.ts"
  },
  "prisma": {
    "seed": "bun run prisma:seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@libsql/client": "^0.15.15",
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "adm-zip": "^0.5.16",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-swc": "^1.5.7",
    "vitest": "^3.2.4"
  }
}
